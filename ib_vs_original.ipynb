    "bars2 = ax1.bar(x + w/2, ib_kl,   w, color=TEAL,  alpha=0.85,\n",
    "                label='IB-Guided (your framework)', edgecolor='white', lw=0.5)\n",
    "\n",
    "for bar, val in zip(bars1, orig_kl):\n",
    "    if val > 0:\n",
    "        ax1.text(bar.get_x()+bar.get_width()/2, val+0.08,\n",
