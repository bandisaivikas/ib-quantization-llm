    "# Cell 5 — THE MAIN COMPARISON FIGURE\n",
    "\n",
    "NAVY='#1A237E'; TEAL='#00796B'; ROSE='#C62828'\n",
    "AMBER='#E65100'; GRAY='#9E9E9E'; WHITE='#FFFFFF'\n",
    "LTEAL='#E0F2F1'; LROSE='#FFEBEE'; LAMBER='#FFF3E0'\n",
    "\n",
    "fig = plt.figure(figsize=(22, 20), facecolor=WHITE)\n",
