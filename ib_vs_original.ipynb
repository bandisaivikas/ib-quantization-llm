    "for bar, val in zip(bars2, ib_kl):\n",
    "    if val > 0:\n",
    "        ax1.text(bar.get_x()+bar.get_width()/2, val+0.08,\n",
    "                 f'{val:.3f}', ha='center', fontsize=8.5, color=TEAL, fontweight='bold')\n",
    "\n",
    "ax1.set_xticks(x)\n",
    "ax1.set_xticklabels([f'{b:.0f}-bit\\n({b/8*124:.0f}MB)' for b in bit_rates], fontsize=9)\n",
    "ax1.axhline(fp32['kl_cal'], color=GRAY, lw=1, ls=':', label='FP32 reference (0.000)')\n",
