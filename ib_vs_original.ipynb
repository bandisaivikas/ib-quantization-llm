    "ax4.legend(fontsize=9)\n",
    "\n",
    "# ── PLOT 5: Silent degradation proof ─────────────────────────────\n",
    "ax5 = fig.add_subplot(gs[1, 2])\n",
    "style(ax5, 'Silent Degradation Proof\\n(why accuracy alone fails)',\n",
    "      'Configuration', '')\n",
    "ax5r = ax5.twinx()\n",
    "\n",
    "# Only show the key configs\n",
    "key = [r for r in results if r['group'] in ('fp32','original') and r['bits'] in (32,8,4)]\n",
    "key_labels = ['FP32', 'INT8', 'INT4']\n",
    "kx = np.arange(3)\n",
    "key_acc = [r['acc_cal'] for r in key]\n",
    "key_kl  = [r['kl_cal']  for r in key]\n",
    "\n",
