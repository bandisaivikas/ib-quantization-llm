    "    for sp in ax.spines.values(): sp.set_edgecolor('#DDDDDD')\n",
    "\n",
    "orig = [r for r in results if r['group'] in ('original','fp32')]\n",
    "ib   = [r for r in results if r['group'] == 'ib']\n",
    "fp32 = next(r for r in results if r['group']=='fp32')\n",
    "\n",
    "# ── PLOT 1: KL-D side by side at each bit rate ──────────────────\n",
    "ax1 = fig.add_subplot(gs[0, :2])\n",
    "style(ax1, 'KL-Divergence: Original vs IB at Each Bit Rate',\n",
    "      'Average Bit Rate', 'KL-Divergence (lower = better)')\n",
    "\n",
    "# group by bit rate\n",
