   "source": [
    "# IB Quantization vs Original Quantization — Side by Side\n",
    "## GPT-2 Small · The Core Comparison\n",
    "\n",
    "**One question:** At the same memory budget, which approach preserves more information?\n",
    "\n",
    "| | Original | Your IB Framework |\n",
    "|---|---|---|\n",
    "| Objective | min ‖W − Q(W)‖² | min information loss |\n",
    "| Layer treatment | uniform | per-layer β |\n",
    "| Operating points | 4-bit or 8-bit | 4,5,6,7,8-bit |\n",
    "| Detects silent degradation | No | Yes |\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1 — Setup (run once)\n",
    "import subprocess\n",
    "subprocess.run(['pip','install','transformers','scipy','matplotlib','-q'],check=True)\n",
    "\n",
    "import torch, numpy as np, matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import matplotlib.gridspec as gridspec\n",
    "from matplotlib.lines import Line2D\n",
    "from copy import deepcopy\n",
    "from transformers import GPT2LMHeadModel, GPT2Tokenizer\n",
    "import warnings; warnings.filterwarnings('ignore')\n",
    "import random\n",
    "\n",
    "DEVICE = 'cuda' if torch.cuda.is_available() else \\\n",
    "         'mps'  if torch.backends.mps.is_available() else 'cpu'\n",
    "torch.manual_seed(42); np.random.seed(42); random.seed(42)\n",
    "\n",
    "tokenizer  = GPT2Tokenizer.from_pretrained('gpt2')\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "model_fp32 = GPT2LMHeadModel.from_pretrained('gpt2',torch_dtype=torch.float32).to(DEVICE)\n",
    "model_fp32.eval()\n",
    "N = len(model_fp32.transformer.h)\n",
    "print(f'GPT-2 Small loaded  |  Device: {DEVICE}  |  Layers: {N}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Data + Core functions\n",
    "CAL = [\n",
    "    ('If a train travels 60 miles per hour for 2 hours,',        ' it travels 120 miles.'),\n",
    "    ('Solve for x: 3x + 7 = 22. The answer is',                  ' x equals 5.'),\n",
    "    ('A store has 20 percent discount on a 50 dollar item.',      ' Final price is 40 dollars.'),\n",
    "    ('The sum of two consecutive integers is 37. They are',       ' 18 and 19.'),\n",
    "    ('A rectangle has perimeter 40cm and length 12cm. Width is',  ' 8 centimeters.'),\n",
    "    ('If you invest 1000 dollars at 5 percent for 2 years,',      ' you get 1102 dollars.'),\n",
    "    ('A car uses 8 liters per 100km. For 250km, fuel needed is',  ' 20 liters.'),\n",
    "    ('Two trains 300km apart move at 60 and 90 km/h. They meet in',' 2 hours.'),\n",
    "    ('The area of a circle with radius 7cm, pi equals 3.14, is',  ' 153.86 square centimeters.'),\n",
    "    ('A recipe needs 2.5 cups for 12 cookies. For 30 cookies,',   ' you need 6.25 cups.'),\n",
    "    ('The ratio of boys to girls is 3:2 with 30 students. Boys:', ' 18 students.'),\n",
    "    ('If 40 percent of a number is 80, the number is',            ' 200.'),\n",
    "    ('A triangle has angles 45 and 60 degrees. Third angle is',   ' 75 degrees.'),\n",
    "    ('Temperature drops 3 degrees per hour. After 5 hours,',      ' drop is 15 degrees.'),\n",
    "    ('Probability of rolling an even number on a die is',         ' one half.'),\n",
    "    ('If 5 workers finish a job in 8 days, 10 workers finish in', ' 4 days.'),\n",
    "    ('Convert 0.75 to a fraction. The answer is',                  ' three quarters.'),\n",
    "    ('The square root of 144 is',                                  ' 12.'),\n",
    "    ('A 10 percent tip on a 60 dollar bill is',                   ' 6 dollars.'),\n",
    "    ('Multiply 13 by 7. The result is',                            ' 91.'),\n",
    "]\n",
    "VAL = [\n",
    "    ('A car travels 90 km per hour for 3 hours.',                 ' It covers 270 kilometers.'),\n",
    "    ('Solve 5x minus 3 equals 22. x equals',                      ' 5.'),\n",
    "    ('Twenty percent of 150 is',                                   ' 30.'),\n",
    "    ('A square has perimeter 36cm. Its side length is',           ' 9 centimeters.'),\n",
    "    ('If 8 workers finish in 6 days, 12 workers finish in',       ' 4 days.'),\n",
    "    ('The cube of 4 is',                                           ' 64.'),\n",
    "    ('A 15 percent tip on 80 dollars is',                         ' 12 dollars.'),\n",
    "    ('Convert 0.25 to a fraction. It is',                          ' one quarter.'),\n",
    "    ('Temperature rises 2 degrees per hour for 7 hours. Rise is', ' 14 degrees.'),\n",
    "    ('Multiply 12 by 11. The answer is',                           ' 132.'),\n",
    "]\n",
    "\n",
    "def tok(d):\n",
    "    f=tokenizer([p+c for p,c in d],return_tensors='pt',padding=True,truncation=True,max_length=64).to(DEVICE)\n",
    "    p=tokenizer([p for p,c in d],return_tensors='pt',padding=True,truncation=True,max_length=64).to(DEVICE)\n",
    "    return f,p\n",
    "\n",
    "ce,cpe=tok(CAL); ve,vpe=tok(VAL)\n",
    "\n",
    "def kl(mp,mq,enc):\n",
    "    v=[]\n",
    "    with torch.no_grad():\n",
    "        for i in range(enc['input_ids'].shape[0]):\n",
    "            ids=enc['input_ids'][i].unsqueeze(0); mask=enc['attention_mask'][i].unsqueeze(0)\n",
    "            lp=mp(input_ids=ids,attention_mask=mask).logits\n",
    "            lq=mq(input_ids=ids,attention_mask=mask).logits\n",
    "            p=torch.softmax(lp,dim=-1).clamp(1e-9,1.); q=torch.softmax(lq,dim=-1).clamp(1e-9,1.)\n",
    "            v.append((p*(p.log()-q.log())).sum(dim=-1).mean().item())\n",
    "    return float(np.mean(v))\n",
    "\n",
    "def accuracy(m,enc,pe):\n",
    "    c=t=0\n",
    "    with torch.no_grad():\n",
    "        for i in range(enc['input_ids'].shape[0]):\n",
    "            ids=enc['input_ids'][i].unsqueeze(0); mask=enc['attention_mask'][i].unsqueeze(0)\n",
    "            pl=int(pe['attention_mask'][i].sum()); fl=int(mask.sum())\n",
    "            lg=m(input_ids=ids,attention_mask=mask).logits\n",
    "            for t2 in range(pl,fl-1): c+=int(lg[0,t2].argmax()==ids[0,t2+1]); t+=1\n",
    "    return c/t*100 if t>0 else 0\n",
    "\n",
    "def q8(l):\n",
    "    with torch.no_grad():\n",
    "        W=l.weight.data.float(); s=W.abs().max()/127+1e-8\n",
    "        l.weight.data=((W/s).round().clamp(-127,127)*s).to(l.weight.dtype)\n",
    "\n",
    "def q4(l):\n",
    "    with torch.no_grad():\n",
    "        W=l.weight.data.float(); s=W.abs().max()/7+1e-8\n",
    "        l.weight.data=((W/s).round().clamp(-7,7)*s).to(l.weight.dtype)\n",
    "\n",
    "def build(alloc):\n",
    "    m=deepcopy(model_fp32); m.eval()\n",
    "    for i,p in alloc.items():\n",
    "        b=m.transformer.h[i]; L=[b.attn.c_attn,b.attn.c_proj,b.mlp.c_fc,b.mlp.c_proj]\n",
    "        if p=='int8':[q8(l) for l in L]\n",
    "        elif p=='int4':[q4(l) for l in L]\n",
    "    return m\n",
    "\n",
    "print('Data and functions ready ✓')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3 — Build ground truth KL map and IB allocation\n",
    "print('Building layer-wise KL-D map...')\n",
    "kl_gt = []\n",
    "for i in range(N):\n",
    "    mq=build({i:'int4'}); kl_gt.append(kl(model_fp32,mq,ce))\n",
    "    print(f'  Layer {i:2d}: KL = {kl_gt[-1]:.5f}')\n",
    "kl_gt=np.array(kl_gt)\n",
    "\n",
    "def ib_alloc(target):\n",
    "    b=(kl_gt-kl_gt.min())/(kl_gt.max()-kl_gt.min()+1e-9)\n",
    "    b=b/(b.mean()+1e-9)\n",
    "    sl=np.argsort(b)[::-1]\n",
    "    k=int(round(N*(target-4)/4)); k=max(0,min(k,N))\n",
    "    return {int(l):('int8' if r<k else 'int4') for r,l in enumerate(sl)}\n",
    "\n",
    "# Random allocation (simulates non-IB uniform mixing)\n",
    "def rand_alloc(target):\n",
    "    k=int(round(N*(target-4)/4)); k=max(0,min(k,N))\n",
    "    layers=list(range(N)); random.shuffle(layers)\n",
    "    return {l:('int8' if i<k else 'int4') for i,l in enumerate(layers)}\n",
    "\n",
    "print(f'\\nMost critical: Layer {np.argmax(kl_gt)} (KL={kl_gt.max():.3f})')\n",
    "print(f'Least critical: Layer {np.argmin(kl_gt)} (KL={kl_gt.min():.3f})')\n",
    "print(f'Ratio: {kl_gt.max()/kl_gt.min():.1f}× — proves uniform allocation is wrong')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4 — Run ALL configurations\n",
    "print('Running all configurations...\\n')\n",
    "\n",
    "configs = [\n",
    "    # label,                  alloc,                              bits,  group\n",
    "    ('FP32 Baseline',          {},                                32.0,  'fp32'),\n",
    "    # ── Original Quantization (uniform) ──────────────────────────────────────\n",
    "    ('Original: Uniform INT8', {i:'int8' for i in range(N)},      8.0,  'original'),\n",
    "    ('Original: Uniform INT4', {i:'int4' for i in range(N)},      4.0,  'original'),\n",
    "    ('Original: Random 7-bit', rand_alloc(7.0),                   7.0,  'original'),\n",
    "    ('Original: Random 6-bit', rand_alloc(6.0),                   6.0,  'original'),\n",
    "    ('Original: Random 5-bit', rand_alloc(5.0),                   5.0,  'original'),\n",
    "    # ── IB Quantization (your framework) ─────────────────────────────────────\n",
    "    ('IB: 7-bit (9×INT8+3×INT4)', ib_alloc(7.0),                  7.0,  'ib'),\n",
    "    ('IB: 6-bit (6×INT8+6×INT4)', ib_alloc(6.0),                  6.0,  'ib'),\n",
    "    ('IB: 5-bit (3×INT8+9×INT4)', ib_alloc(5.0),                  5.0,  'ib'),\n",
    "]\n",
    "\n",
    "results = []\n",
    "for label, alloc, bits, group in configs:\n",
    "    mq     = model_fp32 if not alloc else build(alloc)\n",
    "    kl_cal = kl(model_fp32, mq, ce) if alloc else 0.0\n",
    "    kl_val = kl(model_fp32, mq, ve) if alloc else 0.0\n",
    "    ac     = accuracy(mq, ce, cpe)\n",
    "    av     = accuracy(mq, ve, vpe)\n",
    "    mem    = 124 * (bits/8)\n",
    "    results.append(dict(label=label,bits=bits,kl_cal=kl_cal,kl_val=kl_val,\n",
    "                        acc_cal=ac,acc_val=av,mem=mem,group=group,alloc=alloc))\n",
    "    g = '← ORIGINAL' if group=='original' else '← YOUR IB' if group=='ib' else ''\n",
    "    print(f'{label:<38} {bits:.0f}bit  KL={kl_cal:.4f}  Acc={ac:.1f}%  {g}')\n",
    "\n",
    "print('\\nDone ✓')"
   ]
  },
